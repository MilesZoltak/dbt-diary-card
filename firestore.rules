rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. OWNER ACCESS (Most important)
    // Matches the user document and everything under it recursively
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      match /{allData=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // 2. PUBLIC PROFILE (For Handshake/Lookup)
    match /users/{userId} {
      allow read: if request.auth != null;
    }

    // 3. CLINICIAN ACCESS (Via sharedWith ACL)
    // We match specific collections to avoid interfering with owner rules
    
    match /users/{userId}/templates/{document=**} {
      allow read: if request.auth != null && 
        exists(/databases/$(database)/documents/users/$(userId)/sharedWith/$(request.auth.uid));
    }

    match /users/{userId}/diaryCards/{document=**} {
      allow read: if request.auth != null && 
        exists(/databases/$(database)/documents/users/$(userId)/sharedWith/$(request.auth.uid));
    }

    // Clinicians need to see their own entry in the patient's sharedWith list
    match /users/{userId}/sharedWith/{clinicianId} {
      allow read: if request.auth != null && request.auth.uid == clinicianId;
    }

    // 4. HANDSHAKE (Patient writing to Clinician's roster)
    match /users/{clinicianId}/roster/{patientId} {
      allow write: if request.auth != null && request.auth.uid == patientId;
    }
  }
}
